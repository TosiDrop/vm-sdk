{
  "name": "vm-sdk",
  "version": "1.0.6",
  "description": "A JavaScript/TypeScript SDK for interacting with the VM API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc",
    "prepack": "npm run build",
    "release:check": "node scripts/validate-release-tag.mjs",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint 'src/**/*.{ts,tsx}'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TosiDrop/vm-sdk"
  },
  "homepage": "https://github.com/TosiDrop/vm-sdk#readme",
  "bugs": {
    "url": "https://github.com/TosiDrop/vm-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sdk",
    "typescript",
    "vm",
    "api",
    "axios"
  ],
  "author": "Blink Labs",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.3.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.0.0",
    "jest": "^30.0.5",
    "ts-jest": "^29.3.2",
    "typescript": "^6.0.3"
  }
}
